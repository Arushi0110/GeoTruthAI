# ============================================================
# GeoTruthAI - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# LOCAL DEV (default)
# -----------------------------------------------------------
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://root:example@geotruthai-mongo:27017/geotruthai?authSource=admin
AI_SERVICE_URL=http://geotruthai-ai:8000
CLIENT_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key

# -----------------------------------------------------------
# PRODUCTION - MongoDB Atlas
# Get from: https://www.mongodb.com/atlas
# Replace <username>, <password>, <cluster>
# -----------------------------------------------------------
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/geotruthai?retryWrites=true&w=majority

# -----------------------------------------------------------
# PRODUCTION - AI Service (Render)
# Value from Render dashboard for geotruthai-ai
# -----------------------------------------------------------
# AI_SERVICE_URL=https://geotruthai-ai.onrender.com

# -----------------------------------------------------------
# PRODUCTION - Frontend (Vercel)
# Value from Vercel dashboard
# Can add multiple: https://geotruthai.vercel.app,https://geotruthai-git-main.vercel.app
# -----------------------------------------------------------
# CLIENT_URL=https://geotruthai.vercel.app

# -----------------------------------------------------------
# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# -----------------------------------------------------------
# JWT_SECRET=your-production-secret-here

# -----------------------------------------------------------
# Cloudinary (optional - for image uploads)
# Get from: https://cloudinary.com
# -----------------------------------------------------------
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# -----------------------------------------------------------
# Frontend Build (Vite)
# -----------------------------------------------------------
# VITE_API_URL=https://geotruthai-server.onrender.com/api

